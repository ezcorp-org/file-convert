{
  "name": "@file-convert/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_ENV=development vite dev --port 5173 --host",
    "prebuild": "svelte-kit sync",
    "build": "bunx --bun vite build",
    "build:npm": "vite build",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:conversion": "playwright test file-conversion-e2e",
    "test:all": "npm run test:unit && npm run test:e2e",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@sveltejs/adapter-cloudflare": "^2",
    "@sveltejs/kit": "^1.30.4",
    "@sveltejs/vite-plugin-svelte": "^2.5.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jszip": "^3.4.1",
    "@types/pdfkit": "^0.17.4",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.0",
    "exceljs": "^4.4.0",
    "exifreader": "^4.36.0",
    "file-type": "^21.3.0",
    "jsdom": "^26.1.0",
    "music-metadata": "^11.10.6",
    "pdfkit": "^0.17.2",
    "postcss": "^8.4.0",
    "puppeteer": "^24.19.0",
    "rollup": "^4.24.4",
    "sharp": "^0.34.5",
    "svelte": "^4.2.20",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^3.0.0",
    "terser": "^5.44.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vite": "^4.5.3",
    "vitest": "^3.2.4",
    "wavefile": "^11.0.0",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "comlink": "^4.4.2",
    "fflate": "^0.8.2",
    "jszip": "^3.10.1",
    "lamejs": "^1.2.1",
    "lucide-svelte": "^0.542.0",
    "mammoth": "^1.10.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.149",
    "sheetjs": "https://cdn.sheetjs.com/xlsx-latest/xlsx-latest.tgz",
    "sirv": "^3.0.2",
    "sirv-cli": "^3.0.1",
    "ssim.js": "^3.5.0",
    "undici": "^7.15.0",
    "uuid": "^13.0.0",
    "web-vitals": "^5.1.0",
    "yaml": "^2.8.1"
  },
  "type": "module",
  "engines": {
    "node": "20.x",
    "npm": ">=8.0.0"
  }
}
